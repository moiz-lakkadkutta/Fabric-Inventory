# ops/.env.backup.example — TASK-CUT-404
#
# Copy to ops/.env.backup on the box that runs the cron job. Never commit
# the real file — it's gitignored.
#
#   cp ops/.env.backup.example ops/.env.backup
#   chmod 600 ops/.env.backup
#
# All lines are sourced as-is into bash; quote anything with spaces.

# ── Postgres source ──────────────────────────────────────────────────────────
# Must match the running DB. On the prod box pull these from
# /opt/fabric/.env.production (POSTGRES_USER / POSTGRES_PASSWORD /
# POSTGRES_DB must be identical, or pg_dump will fail with
# "FATAL: role/database does not exist").
#
# POSTGRES_HOST: the postgres service in docker-compose.prod.yml does
# NOT publish a host port, so `localhost:5432` from the host won't
# reach it. The documented cron invocation runs the dump inside the
# docker network via `docker compose exec -T postgres ...`; the
# host-side POSTGRES_HOST below is only honoured if you switch to
# option (b) in docs/ops/deployment-runbook.md §9b.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fabric
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=fabric_prod

# Path where local copies of the encrypted dumps live. Pruned to
# BACKUP_RETENTION_DAYS just like the bucket.
BACKUP_DIR=./ops/backups
BACKUP_RETENTION_DAYS=7

# Optional: pin pg_dump if multiple postgres-client versions are installed.
# BACKUP_PG_DUMP_BIN=/usr/lib/postgresql/16/bin/pg_dump

# ── Encryption-at-rest passphrase (gpg --symmetric, AES256) ──────────────────
# Generate with:  openssl rand -base64 48
# Store the same value in:
#   - this file on the prod box (chmod 600)
#   - a password manager (1Password / Bitwarden / paper in a safe)
# Losing this passphrase = losing the backups.
BACKUP_GPG_PASSPHRASE=replace-me-with-a-strong-random-string

# ── Object storage (S3-compatible: Backblaze B2 by default) ─────────────────
# Backblaze B2 endpoints look like:
#   https://s3.us-east-005.backblazeb2.com   (region = us-east-005)
#   https://s3.eu-central-003.backblazeb2.com (region = eu-central-003)
#
# Hetzner Object Storage endpoints look like:
#   https://fsn1.your-objectstorage.com      (region = fsn1)
#   https://nbg1.your-objectstorage.com      (region = nbg1)
#
# If you swap providers, only B2_ENDPOINT_URL + B2_REGION need to change.
# The variable names are kept as B2_* for code-grep simplicity.

B2_BUCKET=fabric-erp-backups
B2_ACCESS_KEY_ID=replace-me
B2_SECRET_KEY=replace-me
B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
