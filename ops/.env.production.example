# Production env template — copied to /opt/fabric/.env.production on the
# Hetzner CX22 during first-time provisioning. NEVER commit the
# populated version. Generated values are recorded in 1Password
# (vault: "Fabric ERP — Prod") after first provisioning.
#
# Rotate JWT_SECRET if it ever leaks (signs all session tokens).
# Rotate POSTGRES_PASSWORD only with downtime planned (the container
# needs a restart to re-read it).

# ────────────────────────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────────────────────────
POSTGRES_USER=fabric
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM_32_CHARS
POSTGRES_DB=fabric_prod

# ────────────────────────────────────────────────────────────────────
# App auth + identity
# ────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_32_BYTE_RANDOM
ENVIRONMENT=prod
LOG_LEVEL=INFO

# CORS — allowlist origins the FE serves from. Wildcard '*' is rejected
# at startup when ENVIRONMENT=prod (see backend/app/config.py).
CORS_ORIGINS=https://app.taana.in

# Where the FE lives, used to build links inside emails (password
# reset, invite). MUST be HTTPS in prod.
FRONTEND_URL=https://app.taana.in

# ────────────────────────────────────────────────────────────────────
# Sentry (BE) — leave blank to disable; set to enable error capture.
# ────────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod

# ────────────────────────────────────────────────────────────────────
# Mailgun — CUT-405 email provider. All three must be set together
# (partial config falls back to ConsoleEmailAdapter, which prints to
# stdout — fine for dev, broken for prod).
#
# DNS pre-flight (see docs/ops/deployment-runbook.md § Mailgun):
#   1. Verify the domain in the Mailgun dashboard.
#   2. Add the SPF TXT, DKIM TXT, and MX records they provide.
#   3. Wait for "verified" status (~15 min after DNS propagation).
# Indian deliverability without SPF + DKIM is poor; do not skip.
# ────────────────────────────────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.taana.in
MAILGUN_SENDER=Fabric ERP <no-reply@mg.taana.in>

# ────────────────────────────────────────────────────────────────────
# Caddy — Let's Encrypt contact email + the public hostname.
# ────────────────────────────────────────────────────────────────────
CADDY_DOMAIN=app.taana.in
CADDY_EMAIL=ops@taana.in

# ────────────────────────────────────────────────────────────────────
# Image tags pushed by the deploy workflow. The workflow writes the
# git tag (e.g. v0.1.0) here on each deploy so rollback is just
# `docker compose pull` after re-writing this line by hand.
# ────────────────────────────────────────────────────────────────────
GHCR_OWNER=moiz-lakkadkutta
IMAGE_TAG=latest
