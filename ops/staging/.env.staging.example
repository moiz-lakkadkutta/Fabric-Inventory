# Template for /opt/fabric/.env.staging on the Hetzner box.
#
# DO NOT commit the populated version. The deploy workflow writes this file
# on the box from GitHub Actions secrets. Rotate JWT_SECRET if it ever leaks.

POSTGRES_USER=fabric
POSTGRES_PASSWORD=replace-with-strong-random
POSTGRES_DB=fabric_staging

JWT_SECRET=replace-with-32-byte-random
ENVIRONMENT=staging
LOG_LEVEL=INFO

# Sentry — leave blank to disable; set to the staging DSN to enable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging

# Caddy — Let's Encrypt contact email for cert renewal alerts.
CADDY_EMAIL=ops@taana.in

# Image tags pushed by the deploy workflow.
API_IMAGE=ghcr.io/moiz-l/fabric-api:latest
WEB_IMAGE=ghcr.io/moiz-l/fabric-web:latest
