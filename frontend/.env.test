# Vitest reads this file (mode=test) and it overrides values from .env.
# Tests must run in mock mode regardless of what a dev sets in .env for
# browser/live use. Without this, a dev running the audit's setup
# (`VITE_API_MODE=live`) sees every page-rendering test fail because
# IS_LIVE=true causes queries to hit a non-existent backend in jsdom.
VITE_API_MODE=mock
