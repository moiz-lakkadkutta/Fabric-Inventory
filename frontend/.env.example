# All browser API calls go through the same-origin Vite proxy at /api,
# which forwards to VITE_API_TARGET (defaults to http://localhost:8000).
# Override VITE_API_TARGET in your shell when the backend lives elsewhere.
VITE_API_BASE_URL=/api

# Toggle the live backend branch of every TanStack Query hook. Defaults
# to "mock" (click-dummy fixtures); set to "live" to talk to the API.
VITE_API_MODE=mock
