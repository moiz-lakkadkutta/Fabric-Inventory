FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:0.5 /uv /uvx /bin/

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# CUT-205: WeasyPrint runtime libs. Per the Wave-1 spike
# (docs/spikes/pdf-rendering-tech.md), Pango/HarfBuzz/Cairo + Noto fonts
# render the GST tax-invoice PDF including Devanagari/Gujarati item names.
RUN apt-get update && apt-get install -y --no-install-recommends \
        libpango-1.0-0 \
        libpangoft2-1.0-0 \
        libharfbuzz-subset0 \
        libcairo2 \
        fonts-noto \
        fonts-noto-cjk \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml ./
COPY uv.lock* ./

RUN uv sync --frozen --no-install-project || uv sync --no-install-project

COPY entrypoint.dev.sh /usr/local/bin/entrypoint.dev.sh
RUN chmod +x /usr/local/bin/entrypoint.dev.sh

EXPOSE 8000

# Entrypoint runs `alembic upgrade head` before uvicorn so a fresh clone via
# `make dev` produces a migrated DB. Without this, the api container boots
# against an empty schema and every endpoint 500s on first request — that's
# the P0-2 outage QA caught on 2026-05-06.
ENTRYPOINT ["/usr/local/bin/entrypoint.dev.sh"]
CMD ["uv", "run", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
