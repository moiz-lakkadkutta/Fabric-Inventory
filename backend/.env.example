# Runtime DB connection used by the FastAPI app.
# Per TASK-INT-16 (cutover from INT-9), production runs as `fabric_app`
# (NOBYPASSRLS) so RLS is enforced — the superuser role would silently
# bypass every policy. Tests in `tests/test_rls_force.py` continue to
# verify this role attribute and the WITH CHECK enforcement.
DATABASE_URL=postgresql+asyncpg://fabric_app:fabric_app_dev@localhost:5432/fabric_erp

# DDL connection used by Alembic. Stays as the table-owner/superuser role so
# migrations can ALTER TABLE / GRANT regardless of how DATABASE_URL is scoped.
MIGRATION_DATABASE_URL=postgresql+asyncpg://fabric:fabric_dev@localhost:5432/fabric_erp

REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-prod-must-be-long-enough
ENVIRONMENT=dev
LOG_LEVEL=INFO
CORS_ORIGINS=
SENTRY_DSN=

# PII envelope-encryption master KEK (32 bytes, base64). Used to
# wrap each org's per-tenant Data Encryption Key. Generate with:
#     openssl rand -base64 32
# Leave blank in dev and a deterministic test KEK is used (NOT secret;
# any non-dev environment refuses to start without a real value).
PII_MASTER_KEY=
