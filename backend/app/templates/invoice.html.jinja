<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ doc_title }} — {{ invoice.full_number }}</title>
  <style>
    /* CUT-205 — A4 page sizing for WeasyPrint. Per the wireframe at
       docs/spikes/invoice-template-wireframe.html. Layout deliberately
       stays "basic CSS"; WeasyPrint's CSS subset doesn't cover modern
       flex tricks but grid + table + @page are stable. */
    @page {
      size: A4;
      margin: 14mm 12mm 14mm 12mm;
      @bottom-center {
        content: "Page " counter(page) " of " counter(pages);
        font-family: "Noto Sans", "Helvetica", "Arial", sans-serif;
        font-size: 9pt;
        color: #666;
      }
    }
    html, body {
      font-family: "Noto Sans", "Helvetica", "Arial", sans-serif;
      font-size: 10pt;
      color: #111;
      line-height: 1.4;
      margin: 0;
      padding: 0;
      background: #fff;
    }
    .invoice { max-width: 186mm; margin: 0 auto; }

    .doc-title {
      text-align: center;
      font-size: 16pt;
      font-weight: 700;
      letter-spacing: 0.5px;
      border-bottom: 2px solid #111;
      padding-bottom: 4mm;
      margin-bottom: 6mm;
    }
    .doc-title .alt {
      display: block;
      font-size: 9pt;
      color: #666;
      font-weight: 400;
      letter-spacing: 0;
      margin-top: 2mm;
    }

    .parties {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6mm;
      margin-bottom: 6mm;
    }
    .party { border: 1px solid #ddd; padding: 4mm; border-radius: 2px; }
    .party .name { font-weight: 700; font-size: 11pt; margin-bottom: 1.5mm; }
    .party .meta { font-size: 9pt; color: #333; }
    .party .meta div { margin-bottom: 1mm; }
    .party .label {
      display: inline-block;
      width: 28mm;
      color: #777;
      font-size: 8.5pt;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 4mm 6mm;
      border: 1px solid #ddd;
      padding: 3.5mm 4mm;
      margin-bottom: 6mm;
      border-radius: 2px;
      background: #fafafa;
    }
    .meta-grid .cell .k {
      display: block;
      font-size: 8pt;
      color: #777;
      letter-spacing: 0.4px;
      text-transform: uppercase;
      margin-bottom: 0.5mm;
    }
    .meta-grid .cell .v {
      font-size: 10pt;
      font-weight: 600;
      color: #111;
    }

    table.lines {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 5mm;
      font-size: 9pt;
    }
    table.lines thead th {
      background: #111;
      color: #fff;
      font-weight: 600;
      text-align: left;
      padding: 2.5mm 2mm;
      font-size: 8.5pt;
      letter-spacing: 0.3px;
      text-transform: uppercase;
    }
    table.lines tbody td {
      padding: 2mm 2mm;
      border-bottom: 1px solid #eee;
      vertical-align: top;
    }
    table.lines tbody tr:nth-child(even) td { background: #fafafa; }
    table.lines tbody tr { page-break-inside: avoid; }
    table.lines td.r, table.lines th.r { text-align: right; }
    table.lines td.c, table.lines th.c { text-align: center; }
    table.lines td.desc { font-weight: 500; }
    table.lines td.hsn { font-family: "Courier New", monospace; font-size: 8.5pt; }

    .totals-row {
      display: grid;
      grid-template-columns: 1fr 70mm;
      gap: 6mm;
      margin-bottom: 6mm;
    }
    .totals { border: 1px solid #ddd; padding: 3mm 4mm; font-size: 10pt; }
    .totals dl {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 1.5mm 6mm;
      margin: 0;
    }
    .totals dt { color: #555; }
    .totals dd { margin: 0; text-align: right; font-variant-numeric: tabular-nums; }
    .totals .grand {
      border-top: 2px solid #111;
      margin-top: 2mm;
      padding-top: 2mm;
      font-weight: 700;
      font-size: 12pt;
    }
    .totals .grand dt { color: #111; }

    .in-words {
      border: 1px solid #ddd;
      padding: 3mm 4mm;
      border-radius: 2px;
      font-size: 9.5pt;
      margin-bottom: 5mm;
    }
    .in-words .label {
      display: block;
      font-size: 8pt;
      color: #777;
      letter-spacing: 0.4px;
      text-transform: uppercase;
      margin-bottom: 1mm;
    }
    .in-words .value { font-style: italic; }

    .footer {
      display: grid;
      grid-template-columns: 1fr 70mm;
      gap: 6mm;
      margin-top: 8mm;
      page-break-inside: avoid;
    }
    .footer .qr-slot { font-size: 8pt; color: #888; }
    .footer .signature { text-align: right; font-size: 9pt; }
    .footer .signature .firm {
      font-weight: 700;
      margin-bottom: 14mm;
      color: #111;
    }
    .footer .signature .role { color: #555; font-size: 8.5pt; }

    .marker {
      display: inline-block;
      padding: 0.5mm 2mm;
      border-radius: 2px;
      background: #fee;
      color: #a11;
      font-size: 8.5pt;
      font-weight: 600;
      letter-spacing: 0.3px;
    }
    .marker.no { background: #efefef; color: #555; }
  </style>
</head>
<body>

<div class="invoice">

  <!-- Field 1 — Title -->
  <div class="doc-title">
    {{ doc_title }}
    <span class="alt">(Original for Recipient · Duplicate for Transporter · Triplicate for Supplier)</span>
  </div>

  <!-- Fields 2 + 3 — Seller and Buyer -->
  <div class="parties">

    <!-- Field 2 — Seller -->
    <div class="party">
      <div class="name">{{ seller.name }}</div>
      <div class="meta">
        {% if seller.gstin %}<div><span class="label">GSTIN:</span> {{ seller.gstin }}</div>{% endif %}
        {% if seller.state_code %}<div><span class="label">State Code:</span> {{ seller.state_code }}{% if seller.state_name %} ({{ seller.state_name }}){% endif %}</div>{% endif %}
        {% if seller.address %}<div><span class="label">Address:</span> {{ seller.address }}</div>{% endif %}
        {% if seller.phone %}<div><span class="label">Phone:</span> {{ seller.phone }}</div>{% endif %}
        {% if seller.email %}<div><span class="label">Email:</span> {{ seller.email }}</div>{% endif %}
      </div>
    </div>

    <!-- Field 3 — Buyer -->
    <div class="party">
      <div class="name">{{ buyer.name }}</div>
      <div class="meta">
        {% if buyer.gstin %}<div><span class="label">GSTIN:</span> {{ buyer.gstin }}</div>{% endif %}
        {% if buyer.state_code %}<div><span class="label">State Code:</span> {{ buyer.state_code }}{% if buyer.state_name %} ({{ buyer.state_name }}){% endif %}</div>{% endif %}
        {% if buyer.address %}<div><span class="label">Address:</span> {{ buyer.address }}</div>{% endif %}
        {% if buyer.phone %}<div><span class="label">Phone:</span> {{ buyer.phone }}</div>{% endif %}
      </div>
    </div>
  </div>

  <!-- Fields 4 + 5 + 6 — Invoice meta strip -->
  <div class="meta-grid">
    <div class="cell">
      <span class="k">Invoice Number</span>
      <span class="v">{{ invoice.full_number }}</span>
    </div>
    <div class="cell">
      <span class="k">Invoice Date</span>
      <span class="v">{{ invoice.date_display }}</span>
    </div>
    <div class="cell">
      <span class="k">Due Date</span>
      <span class="v">{% if invoice.due_date_display %}{{ invoice.due_date_display }}{% else %}—{% endif %}</span>
    </div>
    <div class="cell">
      <span class="k">Place of Supply</span>
      <span class="v">{{ invoice.place_of_supply_state or '—' }}{% if invoice.place_of_supply_name %} — {{ invoice.place_of_supply_name }}{% endif %}</span>
    </div>
    <div class="cell">
      <span class="k">Reverse Charge</span>
      <span class="v"><span class="marker no">No</span></span>
    </div>
    <div class="cell">
      <span class="k">Tax Type</span>
      <span class="v">{{ invoice.tax_type_label }}</span>
    </div>
    <div class="cell">
      <span class="k">Lifecycle</span>
      <span class="v">{{ invoice.lifecycle_status }}</span>
    </div>
    <div class="cell">
      <span class="k">E-Way Bill</span>
      <span class="v">— (under threshold)</span>
    </div>
  </div>

  <!-- Field 7 — Line items -->
  <table class="lines">
    <thead>
      <tr>
        <th class="c" style="width:7mm;">#</th>
        <th class="desc" style="width:60mm;">Item / Description</th>
        <th class="hsn c" style="width:14mm;">HSN</th>
        <th class="r" style="width:12mm;">Qty</th>
        <th class="c" style="width:10mm;">UOM</th>
        <th class="r" style="width:14mm;">Rate (₹)</th>
        <th class="r" style="width:14mm;">Taxable (₹)</th>
        <th class="c" style="width:10mm;">GST %</th>
        {% if tax_split_label == 'IGST' %}
        <th class="r" style="width:14mm;">IGST (₹)</th>
        {% else %}
        <th class="r" style="width:12mm;">CGST (₹)</th>
        <th class="r" style="width:12mm;">SGST (₹)</th>
        {% endif %}
        <th class="r" style="width:18mm;">Line Total (₹)</th>
      </tr>
    </thead>
    <tbody>
      {% for line in lines %}
      <tr>
        <td class="c">{{ line.sequence }}</td>
        <td class="desc">{{ line.item_name }}</td>
        <td class="hsn c">{{ line.hsn_code or '—' }}</td>
        <td class="r">{{ line.qty }}</td>
        <td class="c">{{ line.uom }}</td>
        <td class="r">{{ line.rate }}</td>
        <td class="r">{{ line.taxable }}</td>
        <td class="c">{{ line.gst_rate }}</td>
        {% if tax_split_label == 'IGST' %}
        <td class="r">{{ line.igst }}</td>
        {% else %}
        <td class="r">{{ line.cgst }}</td>
        <td class="r">{{ line.sgst }}</td>
        {% endif %}
        <td class="r">{{ line.line_total }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <!-- Fields 8 + 9 — Totals + Total in words -->
  <div class="totals-row">
    <div class="totals-side">
      <div class="in-words">
        <span class="label">Total Amount in Words</span>
        <div class="value">{{ totals.in_words }}</div>
      </div>
    </div>

    <div class="totals">
      <dl>
        <dt>Subtotal (Taxable Value)</dt>   <dd>₹ {{ totals.subtotal }}</dd>
        <dt>IGST</dt>                        <dd>₹ {{ totals.igst }}</dd>
        <dt>CGST</dt>                        <dd>₹ {{ totals.cgst }}</dd>
        <dt>SGST</dt>                        <dd>₹ {{ totals.sgst }}</dd>
        <dt>Total GST</dt>                   <dd>₹ {{ totals.gst }}</dd>
        <dt>Round-off</dt>                   <dd>₹ {{ totals.round_off }}</dd>
      </dl>
      <dl class="grand">
        <dt>Grand Total (₹)</dt>             <dd>₹ {{ totals.grand_total }}</dd>
      </dl>
    </div>
  </div>

  <!-- Field 10 — Signature panel + firm footer -->
  <div class="footer">
    <div class="qr-slot">
      [ IRN QR placeholder — populated when GST e-invoice flag is enabled ]
    </div>
    <div class="signature">
      <div class="firm">For {{ seller.name }}</div>
      <div class="role">Authorised Signatory</div>
    </div>
  </div>

</div>

</body>
</html>
